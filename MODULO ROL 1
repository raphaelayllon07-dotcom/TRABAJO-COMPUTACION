def consultar_paciente_y_citas(base_datos, dni_paciente):
    """Busca eficientemente un paciente y su historial de citas mediante DNI."""
    if dni_paciente not in base_datos["pacientes"]:
        return {"existe": False, "mensaje": f"El paciente con DNI {dni_paciente} no esta registrado.", "datos": None, "citas": []}

    datos_paciente = base_datos["pacientes"][dni_paciente]
    citas_del_paciente = [cita for cita in base_datos["citas"] if cita["id_paciente"] == dni_paciente]
    return {"existe": True, "mensaje": "Paciente encontrado con exito.", "datos": datos_paciente, "citas": citas_del_paciente}


def guardar_datos(base_datos, nombre_archivo="agenda_datos.json"):
    """Guarda la estructura global de datos en un archivo JSON."""
    try:
        with open(nombre_archivo, 'w', encoding='utf-8') as archivo:
            json.dump(base_datos, archivo, indent=4, ensure_ascii=False)
        return True
    except IOError as e:
        print(f"[ERROR PERSISTENCIA] No se pudo escribir en el archivo: {e}")
        return False


def cargar_datos(nombre_archivo="agenda_datos.json"):
    """
    Busca el archivo de persistencia y asegura que la lista de 5 especialistas
    este completamente actualizada y cargada en el sistema.
    """
    if not os.path.exists(nombre_archivo):
        return inicializar_sistema()
    try:
        with open(nombre_archivo, 'r', encoding='utf-8') as archivo:
            datos = json.load(archivo)

        # Forzar actualizacion de la plana medica completa por si quedaban residuos del archivo viejo
        plana_medica_actualizada = inicializar_sistema()["especialistas"]
        datos["especialistas"] = plana_medica_actualizada
        return datos
    except (json.JSONDecodeError, IOError):
        print("[ALERTA] Archivo de datos ilegible. Reestableciendo base de datos de seguridad.")
        return inicializar_sistema()



def mostrar_graficos_distribucion(base_datos):
    """Genera gráficos analíticos vectorizados de distribución en consola."""
    print("\n" + "📊 " + "═"*50)
    print("      📈 DATA VISUALIZATION - DISTRIBUCION DE CITAS")
    print("═"*53)

    if not base_datos["citas"]:
        print("📭 Mensaje: No hay datos suficientes para estructurar graficos analiticos.")
        print("═"*53)
        return

    df = pd.DataFrame(base_datos["citas"])

    # Gráfico 1: Distribución por Especialista
    print("\n[GRÁFICO 1] Volumen de Pacientes por Medico Especialista")
    print("-" * 53)
    df["Medico"] = df["id_especialista"].apply(lambda x: base_datos["especialistas"].get(x, {}).get("nombre", "Desconocido"))
    frecuencia_medicos = df["Medico"].value_counts()

    for medico, conteo in frecuencia_medicos.items():
        barra = "█" * conteo
        print(f" {medico:<22} | {barra} ({conteo} pac)")

    # Gráfico 2: Distribución por Patologías / Diagnósticos Preliminares
    print("\n[GRÁFICO 2] Incidencia de Patologias Detectadas (Diagnostico Preliminar)")
    print("-" * 53)
    frecuencia_diagnosticos = df["diagnostico_preliminar"].value_counts()

    for diagnostico, conteo in frecuencia_diagnosticos.items():
        barra = "■" * conteo
        print(f" {diagnostico:<22} | {barra} ({conteo} casos)")
    print("═"*53)


def exportar_citas_a_excel(base_datos):
    """Convierte la lista de citas en un DataFrame de Pandas y exporta a Excel (.xlsx)."""
    print("\n" + "═"*45)
    print("        📊 EXPORTACION DE AGENDA A EXCEL")
    print("═"*45)

    if not base_datos["citas"]:
        print("📭 Mensaje: No hay datos de citas que procesar para el reporte Excel.")
        print("═"*45)
        return

    try:
        df = pd.DataFrame(base_datos["citas"])

        df["Nombre Paciente"] = df["id_paciente"].apply(lambda x: base_datos["pacientes"].get(x, {}).get("nombre", "No Registrado"))
        df["Médico Especialista"] = df["id_especialista"].apply(lambda x: base_datos["especialistas"].get(x, {}).get("nombre", "No Asignado"))

        df_final = df[["id_cita", "id_paciente", "Nombre Paciente", "Médico Especialista", "fecha", "hora", "sintomas_reportados", "diagnostico_preliminar", "estado"]]
        df_final.columns = ["Código Cita", "DNI Paciente", "Nombre Paciente", "Médico Especialista", "Fecha", "Hora", "Síntomas", "Diagnóstico Inteligente", "Estado Actual"]

        nombre_archivo = "Reporte_Citas_Medicas.xlsx"
        df_final.to_excel(nombre_archivo, index=False)

        print(f"✨ ¡EXITO TOTAL! Se ha generado el reporte ejecutivo de manera limpia.")
        print(f"📁 Archivo creado en la carpeta del proyecto: '{nombre_archivo}'")
        print("═"*45)
    except Exception as e:
        print(f"❌ Error critico en la generacion de la hoja de calculo Pandas: {e}")



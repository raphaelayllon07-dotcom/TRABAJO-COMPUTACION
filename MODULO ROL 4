def menu_principal():
    base_datos = cargar_datos()

    while True:
        print("\n" + "═"*50)
        print("      🏥 SISTEMA GESTION DE CITAS MEDICAS v4.3")
        print("═"*50)
        print("1. Agendar Nueva Cita (Con Diagnostico Inteligente)")
        print("2. Reprogramar Cita Existente")
        print("3. Cancelar Cita")
        print("4. Cierre de Jornada (Confirmacion Masiva)")
        print("5. Panel de Reportes, Analitica y Graficos")
        print("6. Salir del Sistema")
        print("═"*50)

        try:
            opcion = int(input("Seleccione una opción (1-6): "))
        except ValueError:
            print("\n❌ ERROR: Debe ingresar un numero entero.")
            continue

        if opcion == 1:
            print("\n--- AGENDAR CITA Y EVALUACION CLINICA ---")
            dni = input("Ingrese DNI del paciente: ").strip()
            es_valido, msg_val = validar_dni(dni)
            if not es_valido:
                print(msg_val)
                continue

            res_paciente = consultar_paciente_y_citas(base_datos, dni)
            if not res_paciente["existe"]:
                print("⚠️ Paciente no registrado. Procediendo a registro rapido:")
                nombre = input("Nombre completo: ").strip()
                telefono = input("Telefono: ").strip()
                correo = input("Correo electronico: ").strip()
                base_datos["pacientes"][dni] = {"nombre": nombre, "telefono": telefono, "correo": correo}
                guardar_datos(base_datos)

            print("\nEspecialistas y Consultorios Disponibles:")
            for k, v in base_datos["especialistas"].items():
                print(f" [{k}] {v['nombre']} ({v['especialidad']}) -> Horas: {v['horario']}")

            id_esp = input("\nIngrese codigo del especialista (ej. ESP03): ").strip().upper()

            fecha = input("Ingrese fecha de la cita (DD/MM/AAAA): ").strip()
            es_valida, msg_f = validar_fecha(fecha)
            if not es_valida:
                print(msg_f)
                continue

            hora = input("Ingrese hora (HH:MM): ").strip()
            es_valida, msg_h = validar_hora(hora)
            if not es_valida:
                print(msg_h)
                continue

            print("\n📝 Describa brevemente los sintomas o malestares del paciente:")
            sintomas = input("-> ").strip()

            res_agenda = agendar_cita_avanzada(base_datos, dni, id_esp, fecha, hora, sintomas)
            print(f"\n{res_agenda['mensaje']}")

        elif opcion == 2:
            print("\n--- REPROGRAMAR CITA ---")
            id_cita = input("Ingrese el codigo de la cita a modificar (ej. CIT001): ").strip().upper()

            nueva_fecha = input("Ingrese nueva fecha (DD/MM/AAAA): ").strip()
            es_valida, msg_f = validar_fecha(nueva_fecha)
            if not es_valida:
                print(msg_f)
                continue

            nueva_hora = input("Ingrese nueva hora (HH:MM): ").strip()
            es_valida, msg_h = validar_hora(nueva_hora)
            if not es_valida:
                print(msg_h)
                continue

            res_reprog = reprogramar_cita(base_datos, id_cita, nueva_fecha, nueva_hora)
            print(f"\n{res_reprog['mensaje']}")

        elif opcion == 3:
            print("\n--- CANCELAR CITA ---")
            id_cita = input("Ingrese el codigo de la cita a cancelar (ej. CIT001): ").strip().upper()
            res_cancel = cancelar_cita(base_datos, id_cita)
            print(f"\n{res_cancel['mensaje']}")

        elif opcion == 4:
            print("\n--- CIERRE JORNADA (ATENCION MASIVA) ---")
            fecha = input("Ingrese la fecha a procesar (DD/MM/AAAA): ").strip()
            es_valida, msg_f = validar_fecha(fecha)
            if not es_valida:
                print(msg_f)
                continue

            res_masivo = confirmar_asistencia_masiva(base_datos, fecha)
            print(f"\n{res_masivo['mensaje']}")

        elif opcion == 5:
            menu_reportes_y_analitica(base_datos)

        elif opcion == 6:
            guardar_datos(base_datos)
            print("\n💾 Base de datos guardada de forma local.")
            break
        else:
            print("\n❌ Opción incorrecta. Intente del 1 al 6.")

